# ================================================================================
# 祖龙 (ZULONG) 系统环境变量配置示例
# 说明：复制此文件为 .env 文件，并根据实际情况修改
# 用法：在启动前执行 source .env (Linux/Mac) 或 .\\.env (Windows PowerShell)
# ================================================================================

# ================================================================================
# 1. 系统基础配置
# ================================================================================

# 运行环境：development / staging / production
export ZULONG_ENV="production"

# 配置文件路径 (可选，默认使用 config/zulong_config.yaml)
# export ZULONG_CONFIG="./config/zulong_config.yaml"

# 数据目录
export ZULONG_DATA_DIR="./data"

# 模型目录
export ZULONG_MODELS_DIR="./models"

# 缓存目录
export ZULONG_CACHE_DIR="./cache"

# 日志级别：DEBUG / INFO / WARNING / ERROR
export ZULONG_LOG_LEVEL="INFO"

# 调试模式：true / false
export ZULONG_DEBUG_MODE="false"

# ================================================================================
# 2. LLM 后端配置
# ================================================================================

# 后端类型：transformer / vllm / sglang / llamaccp / ollama / lmstudio / openai
export ZULONG_LLM_BACKEND="ollama"

# Ollama 配置
export ZULONG_OLLAMA_BASE_URL="http://localhost:11434/v1"
export ZULONG_OLLAMA_MODEL_ID="deepseek-v3.1:671b-cloud"
export ZULONG_OLLAMA_BACKUP_MODEL_ID="qwen3.5:4b"
export ZULONG_OLLAMA_API_KEY="EMPTY"

# vLLM 配置 (如果使用 vLLM)
export ZULONG_VLLM_BASE_URL="http://localhost:8000/v1"
export ZULONG_VLLM_MODEL_ID="/mnt/d/AI/project/zulong_beta4/models/Qwen/Qwen3___5-0.8B-AWQ"
export ZULONG_VLLM_API_KEY="EMPTY"
export ZULONG_VLLM_GPU_MEMORY_UTILIZATION="0.5"
export ZULONG_VLLM_MAX_MODEL_LEN="4096"

# SGLang 配置 (如果使用 SGLang)
export ZULONG_SGLANG_BASE_URL="http://localhost:30000/v1"
export ZULONG_SGLANG_MODEL_ID="/mnt/d/AI/project/zulong_beta4/models/Qwen/Qwen3___5-0.8B-AWQ"
export ZULONG_SGLANG_API_KEY="EMPTY"

# llama.cpp 配置 (如果使用 llama.cpp)
export ZULONG_LLAMACCP_BASE_URL="http://localhost:8080/v1"
export ZULONG_LLAMACCP_MODEL_ID="qwen3.5-4b"
export ZULONG_LLAMACCP_API_KEY="EMPTY"

# LM Studio 配置
export ZULONG_LMSTUDIO_BASE_URL="http://localhost:1234/v1"
export ZULONG_LMSTUDIO_MODEL_ID="qwen3.5-4b"
export ZULONG_LMSTUDIO_API_KEY="EMPTY"

# OpenAI 云端配置
export ZULONG_OPENAI_BASE_URL="https://api.openai.com/v1"
export ZULONG_OPENAI_MODEL_ID="gpt-4o-mini"
export ZULONG_OPENAI_API_KEY="${OPENAI_API_KEY}"  # 从系统环境变量读取

# ================================================================================
# 3. L2 推理引擎配置
# ================================================================================

# 模型配置
export ZULONG_L2_CORE_MODEL="${ZULONG_OLLAMA_MODEL_ID}"
export ZULONG_L2_BACKUP_MODEL="${ZULONG_OLLAMA_BACKUP_MODEL_ID}"

# 生成参数
export ZULONG_L2_MAX_TOKENS="1024"
export ZULONG_L2_TEMPERATURE="0.3"
export ZULONG_L2_TOP_P="0.85"
export ZULONG_L2_REPETITION_PENALTY="1.2"

# 超时配置 (秒)
export ZULONG_L2_CORE_TIMEOUT="30"
export ZULONG_L2_BACKUP_TIMEOUT="30"

# ================================================================================
# 4. 视觉系统配置
# ================================================================================

# 摄像头配置
export ZULONG_CAMERA_ENABLED="false"
export ZULONG_CAMERA_DEVICE_INDEX="1"

# YOLO 模型
export ZULONG_YOLO_MODEL_PATH="models/yolov10n.pt"
export ZULONG_YOLO_DEVICE="cuda"

# ================================================================================
# 5. 音频系统配置
# ================================================================================

# 麦克风配置
export ZULONG_MICROPHONE_ENABLED="true"
export ZULONG_MICROPHONE_DEVICE_INDEX=""  # 空表示使用默认设备

# 扬声器配置
export ZULONG_SPEAKER_ENABLED="true"
export ZULONG_SPEAKER_DEVICE_INDEX=""  # 空表示使用默认设备

# TTS 配置
export ZULONG_TTS_BACKEND="cosyvoice"
export ZULONG_TTS_MODEL_PATH="iic/CosyVoice2-0.5B"

# ================================================================================
# 6. 记忆系统配置
# ================================================================================

# RAG 配置
export ZULONG_RAG_ENABLED="true"
export ZULONG_RAG_DATA_DIR="./data/rag"
export ZULONG_RAG_EMBEDDING_MODEL="BAAI/bge-small-zh-v1.5"

# 经验数据库
export ZULONG_EXPERIENCE_DB_PATH="./data/experience_db/experiences.db"

# ================================================================================
# 7. 工具系统配置
# ================================================================================

# OpenClaw 配置
export ZULONG_OPENCLAW_ENABLED="true"
export ZULONG_OPENCLAW_API_URL="http://localhost:3000"
export ZULONG_OPENCLAW_WEBSOCKET_URL="ws://localhost:5555"

# 网络搜索配置
export ZULONG_WEB_SEARCH_ENABLED="true"
export ZULONG_WEB_SEARCH_ENGINE="searxng"
export ZULONG_SEARXNG_URL="http://localhost:8080"

# 技能包配置
export ZULONG_SKILL_PACKS_ENABLED="true"
export ZULONG_ENABLED_SKILL_PACKS="autogpt_planner,openmanus_reasoner"

# ================================================================================
# 8. Web 服务配置
# ================================================================================

# API 服务器
export ZULONG_API_HOST="localhost"
export ZULONG_API_PORT="3000"

# Web 界面
export ZULONG_WEB_HOST="localhost"
export ZULONG_WEB_PORT="8080"

# WebSocket
export ZULONG_WEBSOCKET_HOST="localhost"
export ZULONG_WEBSOCKET_PORT="5555"

# ================================================================================
# 9. 安全配置
# ================================================================================

# API 密钥 (建议在生产环境中设置)
export ZULONG_API_KEY="your-secret-api-key-here"

# OpenAI API 密钥 (如果使用 OpenAI)
export OPENAI_API_KEY="sk-your-openai-api-key-here"

# ================================================================================
# 10. 监控配置
# ================================================================================

# 性能监控
export ZULONG_PERFORMANCE_MONITORING_ENABLED="true"
export ZULONG_LOG_THRESHOLD_MS="100"

# 调试控制台
export ZULONG_DEBUG_CONSOLE_ENABLED="true"

# ================================================================================
# Windows PowerShell 版本 (将上面的内容保存为 .env.ps1)
# ================================================================================
# $env:ZULONG_ENV="production"
# $env:ZULONG_LLM_BACKEND="ollama"
# $env:ZULONG_OLLAMA_BASE_URL="http://localhost:11434/v1"
# $env:ZULONG_OLLAMA_MODEL_ID="deepseek-v3.1:671b-cloud"
# ... (其他变量类似)
